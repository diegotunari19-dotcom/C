	else if(nu[i] < 0){
		ne++;}}

printf("DOS NÚMEROS ÍNFORMADOS %d SÃO POSITIVOS\n", po);
printf("DOS NÚMEROS ÍNFORMADOS %d SÃO ZERO\n", ze);
printf("DOS NÚMEROS ÍNFORMADOS %d SÃO NEGATIVOS\n", ne);
