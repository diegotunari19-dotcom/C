#include <stdio.h>
int main() 
{ 
int dia; 
printf("INFORME UMA NUMERO ENTRE 1 A 7:\n"); 
scanf("%d" , &dia); 
switch (dia){ 
	case 1: printf("DOMINGO\n"); 
	break; 
	case 2: printf("SEGUNDA\n");
	break; 
	case 3: printf("TERÇA\n"); 
	break; 
	case 4: printf("QUARTA\n"); 
	break; 
	case 5: printf("QUINTA\n"); 
	break;
	case 6: printf("SEXTA\n"); 
	break; 
	case 7: printf("SABADO\n"); 
	break;
	default: printf("NUMERO INVALIDO\n");} 
return 0;
}
